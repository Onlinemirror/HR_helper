# Telegram Bot
BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs with access
ALLOWED_USERS=123456789,987654321

# Google Sheets
SPREADSHEET_ID=your_spreadsheet_id_here

# Google Drive — ID родительской HR-папки (не ссылка, а сам ID)
HR_DRIVE_FOLDER_ID=your_drive_folder_id_here

# Путь к JSON-ключу сервисного аккаунта
GOOGLE_CREDENTIALS_FILE=service_account.json

# Путь к OAuth2 Client credentials (для загрузки файлов на Drive)
OAUTH_CREDENTIALS_FILE=oauth_credentials.json
